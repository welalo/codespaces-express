{
  "name": "codespaces-express",
  "version": "1.0.0",
  "description": "Backend para reservas de pistas de pádel con Node.js, Express, MongoDB y JWT",
  "main": "index.js",
  "scripts": {
    "build": "npm --prefix frontend-app run build",
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "npm run build && node index.js",
    "start:prod": "npm run build && node index.js",
    "start:server": "node index.js",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "nodemon index.js",
    "dev:frontend": "npm --prefix frontend-app run dev"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.2",
    "nodemon": "^3.1.0"
  }
}
